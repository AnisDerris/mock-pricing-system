{
  "title": "Food Delivery — Dynamic Pricing",
  "uid": "food-pricing-main",
  "version": 1,
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "API — Requêtes / sec",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(http_requests_total{job='food-pricing-api'}[1m])",
          "legendFormat": "req/s"
        }
      ],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "API — Latence P99 (ms)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job='food-pricing-api'}[1m])) * 1000",
          "legendFormat": "p99 ms"
        }
      ],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "API — Erreurs 5xx / min",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(http_requests_total{job='food-pricing-api',status=~'5..'}[1m]) * 60",
          "legendFormat": "errors/min"
        }
      ],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Débit HTTP — POST /price",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(http_requests_total{job='food-pricing-api',handler='/price'}[1m])",
          "legendFormat": "POST /price"
        },
        {
          "expr": "rate(http_requests_total{job='food-pricing-api',handler='/price/stream'}[1m])",
          "legendFormat": "POST /price/stream (SSE)"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Latence HTTP p50 / p95 / p99",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{job='food-pricing-api'}[1m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job='food-pricing-api'}[1m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job='food-pricing-api'}[1m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 6,
      "type": "logs",
      "title": "Logs — Services (Loki)",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 10 },
      "datasource": "Loki",
      "targets": [
        {
          "expr": "{service=~\"api|producer|consumer-orders|consumer-drivers|consumer-restaurants|consumer-traffic\"}",
          "legendFormat": ""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "dedupStrategy": "none"
      }
    }
  ]
}
